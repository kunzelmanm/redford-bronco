---
interface ImageItem {
  publicId: string;
  alt: string;
  caption?: string;
}

interface Props {
  images: ImageItem[];
  columns?: 2 | 3 | 4;
  galleryId?: string;
}

const { images, columns = 3, galleryId = `gallery-${Math.random().toString(36).slice(2, 8)}` } = Astro.props;

const CLOUDINARY_CLOUD_NAME = 'dwvpdrvq9';

const imageData = images.map(img => ({
  ...img,
  thumbUrl: `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_600,q_auto,f_auto/${img.publicId}`,
  fullUrl: `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_1600,q_auto,f_auto/${img.publicId}`,
}));
---

<div id={galleryId} data-gallery-id={galleryId} class={`image-gallery cols-${columns}`}>
  {imageData.map(img => (
    <div class="gallery-item">
      <a
        href={img.fullUrl}
        target="_blank"
      >
        <img
          src={img.thumbUrl}
          alt={img.alt}
          class="gallery-thumb"
        />
      </a>
      {img.caption && <div class="gallery-caption">{img.caption}</div>}
    </div>
  ))}
</div>

<style>
  .image-gallery {
    display: grid;
    gap: 16px;
    margin: 40px 0;
  }

  .cols-2 { grid-template-columns: repeat(2, 1fr); }
  .cols-3 { grid-template-columns: repeat(3, 1fr); }
  .cols-4 { grid-template-columns: repeat(4, 1fr); }

  .gallery-item {
    display: flex;
    flex-direction: column;
  }

  .gallery-item a {
    display: block;
    cursor: zoom-in;
    transition: opacity 0.2s, transform 0.2s;
  }

  .gallery-item a:hover {
    opacity: 0.9;
    transform: scale(1.02);
  }

  .gallery-thumb {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .gallery-caption {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    text-align: center;
    margin: 4px 0 0 0;
    font-style: italic;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .image-gallery {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 12px;
    }
  }

  @media (max-width: 480px) {
    .image-gallery {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  document.querySelectorAll<HTMLElement>('[data-gallery-id]').forEach(el => {
    const id = el.dataset.galleryId!;
    const lightbox = new PhotoSwipeLightbox({
      gallery: `#${id}`,
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });

    lightbox.addFilter('itemData', (itemData) => {
      const img = itemData.element?.querySelector('img') as HTMLImageElement | null;
      if (img?.complete && img.naturalWidth) {
        const scale = 1600 / img.naturalWidth;
        itemData.w = 1600;
        itemData.h = Math.round(img.naturalHeight * scale);
      }
      return itemData;
    });

    lightbox.init();
  });
</script>
