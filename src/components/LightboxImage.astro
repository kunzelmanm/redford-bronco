---
interface Props {
  publicId: string;
  alt: string;
  caption?: string;
  size?: 'small' | 'medium' | 'half';
}

const { publicId, alt, caption, size = 'medium' } = Astro.props;

const CLOUDINARY_CLOUD_NAME = 'dwvpdrvq9';

const thumbSizes = { small: 400, medium: 600, half: 800 };
const thumbWidth = thumbSizes[size];
const thumbUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_${thumbWidth},q_auto,f_auto/${publicId}`;
const fullUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_1600,q_auto,f_auto/${publicId}`;
---

<div class={`lightbox-image lightbox-${size}`}>
  <a
    href={fullUrl}
    class="pswp-single"
    target="_blank"
  >
    <img src={thumbUrl} alt={alt} class="lightbox-thumb" />
  </a>
  {caption && <div class="lightbox-caption">{caption}</div>}
</div>

<style>
  .lightbox-image {
    margin: 32px auto;
  }

  .lightbox-small { max-width: 300px; }
  .lightbox-medium { max-width: 450px; }
  .lightbox-half { max-width: 50%; }

  .lightbox-image a {
    display: block;
    cursor: zoom-in;
    transition: opacity 0.2s;
  }

  .lightbox-image a:hover {
    opacity: 0.9;
  }

  .lightbox-thumb {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .lightbox-caption {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    text-align: center;
    margin: 4px 0 0 0;
    font-style: italic;
    line-height: 1.2;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.pswp-single',
    children: false,
    pswpModule: () => import('photoswipe'),
  });

  lightbox.addFilter('itemData', (itemData) => {
    const img = itemData.element?.querySelector('img') as HTMLImageElement | null;
    if (img?.complete && img.naturalWidth) {
      const scale = 1600 / img.naturalWidth;
      itemData.w = 1600;
      itemData.h = Math.round(img.naturalHeight * scale);
    }
    return itemData;
  });

  lightbox.init();
</script>
