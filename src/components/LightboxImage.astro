---
// Lightbox image component for blog posts
// Shows small inline image that expands to full size on click
interface Props {
  publicId: string;
  alt: string;
  caption?: string;
  size?: 'small' | 'medium' | 'half';
}

const { publicId, alt, caption, size = 'medium' } = Astro.props;

const CLOUDINARY_CLOUD_NAME = 'dwvpdrvq9';

// Thumbnail sizes
const thumbSizes = {
  small: 400,
  medium: 600,
  half: 800
};

const thumbWidth = thumbSizes[size];
const thumbUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_${thumbWidth},q_auto,f_auto/${publicId}`;
const fullUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_1600,q_auto,f_auto/${publicId}`;
---

<div class={`lightbox-image lightbox-${size}`}>
  <img 
    src={thumbUrl} 
    alt={alt}
    class="lightbox-thumb"
    data-full={fullUrl}
  />
  {caption && <p class="lightbox-caption">{caption}</p>}
</div>

<style>
  .lightbox-image {
    margin: 32px auto;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  
  .lightbox-image:hover {
    opacity: 0.9;
  }
  
  .lightbox-small {
    max-width: 300px;
  }
  
  .lightbox-medium {
    max-width: 450px;
  }
  
  .lightbox-half {
    max-width: 50%;
  }
  
  .lightbox-thumb {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  
  .lightbox-caption {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-align: center;
    margin: 6px 0 0 0;
    font-style: italic;
    line-height: 1.3;
  }
</style>

<script>
  // Lightbox functionality
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('.lightbox-thumb');
    
    images.forEach(img => {
      img.addEventListener('click', (e) => {
        const target = e.target as HTMLImageElement;
        const fullUrl = target.dataset.full;
        if (!fullUrl) return;
        
        // Create lightbox overlay
        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        overlay.innerHTML = `
          <div class="lightbox-container">
            <img src="${fullUrl}" alt="${target.alt}" />
            <button class="lightbox-close">✕</button>
          </div>
        `;
        
        document.body.appendChild(overlay);
        document.body.style.overflow = 'hidden';
        
        // Close on click
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay || (e.target as HTMLElement).className === 'lightbox-close') {
            document.body.removeChild(overlay);
            document.body.style.overflow = '';
          }
        });
        
        // Close on escape
        const escHandler = (e: KeyboardEvent) => {
          if (e.key === 'Escape') {
            document.body.removeChild(overlay);
            document.body.style.overflow = '';
            document.removeEventListener('keydown', escHandler);
          }
        };
        document.addEventListener('keydown', escHandler);
      });
    });
  });
</script>

<style is:global>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    animation: fadeIn 0.2s;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .lightbox-container {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
  }
  
  .lightbox-container img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
  }
  
  .lightbox-close {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
    transition: opacity 0.2s;
  }
  
  .lightbox-close:hover {
    opacity: 0.7;
  }
</style>
