---
// Two-column layout component for blog posts
// Allows image on one side, text on the other
interface Props {
  imagePublicId: string;
  imageAlt: string;
  imageCaption?: string;
  imagePosition?: 'left' | 'right';
  imageSize?: 'small' | 'medium' | 'large';
}

const { 
  imagePublicId, 
  imageAlt, 
  imageCaption,
  imagePosition = 'left',
  imageSize = 'medium'
} = Astro.props;

const CLOUDINARY_CLOUD_NAME = 'dwvpdrvq9';

// Image sizes based on column proportion
const imageSizes = {
  small: 400,   // ~30% of container
  medium: 600,  // ~40% of container  
  large: 800    // ~50% of container
};

const imageWidth = imageSizes[imageSize];
const imageUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_${imageWidth},q_auto,f_auto/${imagePublicId}`;
const fullUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_1600,q_auto,f_auto/${imagePublicId}`;
---

<div class={`two-column ${imagePosition === 'right' ? 'image-right' : 'image-left'} size-${imageSize}`}>
  <div class="column-image">
    <img 
      src={imageUrl} 
      alt={imageAlt}
      class="column-thumb"
      data-full={fullUrl}
    />
    {imageCaption && <p class="column-caption">{imageCaption}</p>}
  </div>
  <div class="column-text">
    <slot />
  </div>
</div>

<style>
  .two-column {
    display: grid;
    gap: 32px;
    margin: 40px 0;
    align-items: start;
  }
  
  .size-small {
    grid-template-columns: 1fr 2fr;
  }
  
  .size-medium {
    grid-template-columns: 2fr 3fr;
  }
  
  .size-large {
    grid-template-columns: 1fr 1fr;
  }
  
  .image-right {
    direction: rtl;
  }
  
  .image-right > * {
    direction: ltr;
  }
  
  .column-image {
    position: sticky;
    top: 90px;
    align-self: start;
  }
  
  .column-thumb {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: opacity 0.2s;
  }
  
  .column-thumb:hover {
    opacity: 0.9;
  }
  
  .column-caption {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin: 6px 0 0 0;
    font-style: italic;
    line-height: 1.3;
  }
  
  .column-text {
    font-size: 17px;
    line-height: 1.8;
    padding-top: 0;
  }
  
  .column-text :global(p) {
    margin-bottom: 20px;
  }
  
  .column-text :global(p:first-child::first-letter) {
    all: unset;
  }
  
  .column-text :global(h3) {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--red);
    margin: 24px 0 12px;
  }
  
  .column-text :global(ul) {
    margin: 16px 0;
    padding-left: 24px;
  }
  
  .column-text :global(li) {
    margin-bottom: 8px;
  }
  
  @media (max-width: 768px) {
    .two-column {
      grid-template-columns: 1fr !important;
      gap: 20px;
    }
    
    .column-image {
      position: relative;
      top: 0;
    }
    
    .image-right {
      direction: ltr;
    }
  }
</style>

<script>
  // Lightbox functionality for column images
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('.column-thumb');
    
    images.forEach(img => {
      img.addEventListener('click', (e) => {
        const target = e.target as HTMLImageElement;
        const fullUrl = target.dataset.full;
        if (!fullUrl) return;
        
        // Create lightbox overlay
        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        overlay.innerHTML = `
          <div class="lightbox-container">
            <img src="${fullUrl}" alt="${target.alt}" />
            <button class="lightbox-close">✕</button>
          </div>
        `;
        
        document.body.appendChild(overlay);
        document.body.style.overflow = 'hidden';
        
        // Close on click
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay || (e.target as HTMLElement).className === 'lightbox-close') {
            document.body.removeChild(overlay);
            document.body.style.overflow = '';
          }
        });
        
        // Close on escape
        const escHandler = (e: KeyboardEvent) => {
          if (e.key === 'Escape') {
            document.body.removeChild(overlay);
            document.body.style.overflow = '';
            document.removeEventListener('keydown', escHandler);
          }
        };
        document.addEventListener('keydown', escHandler);
      });
    });
  });
</script>
