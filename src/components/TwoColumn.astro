---
// Two-column layout component for blog posts
// Allows image on one side, text on the other
interface Props {
  imagePublicId: string;
  imageAlt: string;
  imageCaption?: string;
  imagePosition?: 'left' | 'right';
  imageSize?: 'small' | 'medium' | 'large';
}

const { 
  imagePublicId, 
  imageAlt, 
  imageCaption,
  imagePosition = 'left',
  imageSize = 'medium'
} = Astro.props;

const CLOUDINARY_CLOUD_NAME = 'dwvpdrvq9';

// Image sizes based on column proportion
const imageSizes = {
  small: 400,   // ~30% of container
  medium: 600,  // ~40% of container  
  large: 800    // ~50% of container
};

const imageWidth = imageSizes[imageSize];
const imageUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_${imageWidth},q_auto,f_auto/${imagePublicId}`;
const fullUrl = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload/w_1600,q_auto,f_auto/${imagePublicId}`;
---

<div class={`two-column ${imagePosition === 'right' ? 'image-right' : 'image-left'} size-${imageSize}`}>
  <div class="column-image">
    <a
      href={fullUrl}
      class="pswp-single"
      target="_blank"
    >
      <img
        src={imageUrl}
        alt={imageAlt}
        class="column-thumb"
      />
    </a>
    {imageCaption && <div class="column-caption">{imageCaption}</div>}
  </div>
  <div class="column-text">
    <slot />
  </div>
</div>

<style>
  .two-column {
    display: grid;
    gap: 32px;
    margin: 40px 0;
    align-items: start;
  }
  
  .size-small {
    grid-template-columns: 1fr 2fr;
  }
  
  .size-medium {
    grid-template-columns: 2fr 3fr;
  }
  
  .size-large {
    grid-template-columns: 1fr 1fr;
  }
  
  .image-right {
    direction: rtl;
  }
  
  .image-right > * {
    direction: ltr;
  }
  
  .column-image {
    position: sticky;
    top: 90px;
    align-self: start;
  }
  
  .column-image a {
    display: block;
    cursor: zoom-in;
    transition: opacity 0.2s;
  }

  .column-image a:hover {
    opacity: 0.9;
  }

  .column-thumb {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  
  .column-caption {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    margin: 4px 0 0 0;
    font-style: italic;
    line-height: 1.2;
  }
  
  .column-text {
    font-size: 17px;
    line-height: 1.8;
    padding-top: 0;
  }
  
  .column-text :global(p) {
    margin-bottom: 20px;
  }
  
  .column-text :global(p:first-child::first-letter) {
    all: unset;
  }
  
  .column-text :global(h3) {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--red);
    margin: 24px 0 12px;
  }
  
  .column-text :global(ul) {
    margin: 16px 0;
    padding-left: 24px;
  }
  
  .column-text :global(li) {
    margin-bottom: 8px;
  }
  
  @media (max-width: 768px) {
    .two-column {
      grid-template-columns: 1fr !important;
      gap: 20px;
    }
    
    .column-image {
      position: relative;
      top: 0;
    }
    
    .image-right {
      direction: ltr;
    }
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.pswp-single',
    children: false,
    pswpModule: () => import('photoswipe'),
  });

  lightbox.addFilter('itemData', (itemData) => {
    const img = itemData.element?.querySelector('img') as HTMLImageElement | null;
    if (img?.complete && img.naturalWidth) {
      const scale = 1600 / img.naturalWidth;
      itemData.w = 1600;
      itemData.h = Math.round(img.naturalHeight * scale);
    }
    return itemData;
  });

  lightbox.init();
</script>
