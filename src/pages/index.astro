---
import Layout from '../layouts/Layout.astro';
import CloudinaryImage from '../components/CloudinaryImage.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featuredPost = sortedPosts[0];
const latestPosts = sortedPosts.slice(1, 6); // Skip the featured post, take next 5
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    {featuredPost.data.heroImage ? (
      <CloudinaryImage publicId={featuredPost.data.heroImage} alt={featuredPost.data.title} gravity={featuredPost.data.heroGravity} class="hero-bg" />
    ) : (
      <div class="hero-placeholder">
        <span>Photo coming soon — Sand Hollow State Park</span>
      </div>
    )}
    <div class="hero-content">
      <span class="tag">Trail Run — Featured</span>
      <h1 class="hero-title">{featuredPost.data.title}</h1>
      <p class="hero-excerpt">{featuredPost.data.description}</p>
      <div class="hero-meta">
        <span>{new Date(featuredPost.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        <span>·</span>
        <span>Hurricane, UT</span>
        <span>·</span>
        <span>6 min read</span>
      </div>
      <a class="btn-read" href={`/blog/${featuredPost.id}`}>
        Read the Post
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 7h12M8 3l5 4-5 4"/></svg>
      </a>
    </div>
  </section>

  <!-- LATEST POSTS -->
  <div class="section-header">
    <h2>Latest Posts</h2>
  </div>

  <div class="post-grid">
    {latestPosts.map((post, index) => (
      <a class={`post-card ${index === 1 ? 'post-wide' : ''}`} href={`/blog/${post.id}`}>
        <div class="post-card-image">
          {post.data.heroImage ? (
            <CloudinaryImage publicId={post.data.heroImage} alt={post.data.title} width={800} />
          ) : (
            <div class="placeholder"><span>photo — {post.data.title}</span></div>
          )}
        </div>
        <div class="post-card-body">
          <span class="post-card-tag">{post.data.category || 'Post'}</span>
          <h3 class="post-card-title">{post.data.title}</h3>
          <p class="post-card-excerpt">{post.data.description}</p>
          <div class="post-card-meta">
            <span>{new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            <span>6 min</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- ABOUT THE RIG -->
  <div class="about-strip">
    <div class="about-content">
      <span class="tag">About this blog</span>
      <h3>Built for the<br><em>Trail,</em><br>Written on the Road</h3>
      <p>Redford Bronco is a personal log of adventures in and around Hurricane, Utah — trail runs, day trips, and the occasional late-night mod session in the driveway. No sponsored posts. No expertise claimed. Just one Bronco and the Southern Utah desert.</p>
    </div>
    <div class="about-rig">
      <h4>The Rig</h4>
      <ul class="spec-list">
        <li>
          <span class="spec-label">Year / Model</span>
          <span class="spec-val">2025 Ford Bronco</span>
        </li>
        <li>
          <span class="spec-label">Trim</span>
          <span class="spec-val">Badlands</span>
        </li>
        <li>
          <span class="spec-label">Package</span>
          <span class="spec-val">Sasquatch</span>
        </li>
        <li>
          <span class="spec-label">Color</span>
          <span class="spec-val">Ruby Red Metallic</span>
        </li>
        <li>
          <span class="spec-label">Engine</span>
          <span class="spec-val">2.7L EcoBoost V6</span>
        </li>
        <li>
          <span class="spec-label">Tires</span>
          <span class="spec-val">35" Goodyear MTR</span>
        </li>
        <li>
          <span class="spec-label">Base</span>
          <span class="spec-val">Hurricane, UT</span>
        </li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    height: calc(100svh - 72px);
    min-height: 520px;
    max-height: 650px;
    overflow: hidden;
    background: var(--surface2);
  }

  .hero-placeholder {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      var(--surface) 0, var(--surface) 10px,
      var(--surface2) 10px, var(--surface2) 20px
    );
    display: flex; align-items: flex-start; justify-content: flex-end;
    z-index: 0;
  }
  .hero-placeholder span {
    font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted);
    border: 1px solid var(--border); background: var(--bg); padding: 6px 12px;
    margin: 16px 16px 0 0; opacity: 0.5; z-index: 3; align-self: flex-start;
  }

  .hero :global(.hero-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero::after {
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(to top,  rgba(10,8,7,0.96) 0%, rgba(10,8,7,0.7) 45%, rgba(10,8,7,0.3) 70%, transparent 90%),
      linear-gradient(to right, rgba(10,8,7,0.5) 0%, transparent 55%);
    z-index: 1;
  }

  .hero::before {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: var(--red); z-index: 3;
  }

  .hero-content {
    position: absolute; bottom: 0; left: 0;
    padding: 56px 64px;
    z-index: 2;
    max-width: 780px;
    display: flex;
    flex-direction: column;
  }

  .hero-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 64px;
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin: 14px 0 20px;
  }
  .hero-title em {
    color: var(--red);
    font-style: italic;
  }

  .hero-excerpt {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(237,232,224,0.85);
    max-width: 560px;
    margin-bottom: 16px;
  }

  .hero-meta {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    display: flex;
    gap: 10px;
    margin-bottom: 28px;
  }

  .btn-read {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    text-decoration: none;
    border: 1.5px solid var(--red);
    padding: 12px 24px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    align-self: flex-start;
    transition: all 0.25s;
  }
  .btn-read svg { width: 14px; height: 14px; }
  .btn-read:hover {
    background: var(--red);
    color: white;
    transform: translateX(2px);
  }

  /* ── SECTION HEADER ── */
  .section-header {
    padding: 56px 64px 40px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .section-header h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
    white-space: nowrap;
  }
  .section-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── POST GRID ── */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 1px;
  }

  .post-card {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .post-card:hover { background: var(--surface); }

  .post-card-image {
    aspect-ratio: 16/10;
    position: relative;
    overflow: hidden;
    background: var(--surface2);
  }

  .post-card-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .post-card-image .placeholder {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      var(--surface) 0, var(--surface) 8px,
      var(--surface2) 8px, var(--surface2) 16px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card-image .placeholder span {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-align: center;
    padding: 6px 12px;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .post-card-body {
    padding: 24px 24px 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--border);
  }

  .post-card-tag {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--red);
  }

  .post-card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 26px;
    line-height: 1.0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    flex: 1;
  }

  .post-card-excerpt {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
  }

  /* ── WIDE CARD (mod post) ── */
  .post-wide {
    grid-column: span 2;
  }

  .post-wide .post-card-image {
    aspect-ratio: auto;
    min-height: 240px;
  }

  /* ── ABOUT STRIP ── */
  .about-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .about-content {
    padding: 56px 56px;
    border-right: 1px solid var(--border);
  }

  .about-content h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 48px;
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin: 16px 0 24px;
  }
  .about-content h3 em { color: var(--red); }
  .about-content p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(237,232,224,0.75);
  }

  .about-rig {
    padding: 56px 56px;
  }

  .about-rig h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-style: italic;
    font-size: 24px;
    text-transform: uppercase;
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }

  .spec-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .spec-list li {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .spec-list li:first-child {
    padding-top: 0;
  }
  .spec-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .spec-val {
    font-family: 'Barlow', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
    .post-wide { grid-column: span 2; }
  }

  @media (max-width: 1024px) {
    .about-strip { grid-template-columns: 1fr; }
    .about-content { border-right: none; border-bottom: 1px solid var(--border); }
  }

  @media (max-width: 768px) {
    .hero-content { padding: 32px 24px; }
    .hero-title { font-size: 42px; }
    .section-header { padding: 48px 24px 32px; }
    .post-grid { grid-template-columns: 1fr; }
    .post-wide { grid-column: span 1; }
    .about-content, .about-rig { padding: 40px 24px; }
  }
</style>
